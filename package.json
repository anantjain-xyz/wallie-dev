{
  "name": "wallie-dev",
  "version": "0.2.1",
  "private": false,
  "license": "MIT",
  "description": "AI-powered product development automation. Turn Linear issues into structured specs and ship them through a configurable, human-reviewed multi-stage agent pipeline.",
  "homepage": "https://wallie.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anantjain-xyz/wallie-dev.git"
  },
  "bugs": {
    "url": "https://github.com/anantjain-xyz/wallie-dev/issues"
  },
  "keywords": [
    "ai-agents",
    "developer-tools",
    "nextjs",
    "supabase",
    "automation",
    "linear",
    "github"
  ],
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "worker": "node --env-file-if-exists=.env.local --import ./scripts/install-crash-handlers.mjs --import ./scripts/register-server-only.mjs --import tsx src/worker/index.ts"
  },
  "dependencies": {
    "@octokit/app": "^16.1.2",
    "@octokit/webhooks-methods": "^6.0.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.0",
    "@vercel/sandbox": "^1.10.0",
    "clsx": "^2.1.1",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.1",
    "tsx": "^4.19.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.7"
  }
}
