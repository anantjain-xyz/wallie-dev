# Local defaults. On Vercel, mirror the same keys in project env settings and
# set NEXT_PUBLIC_APP_URL to the deployed origin for each environment.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-your-publishable-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=replace-with-your-secret-key

# Master secret for AES-256-GCM at-rest encryption of workspace secrets and
# user-supplied agent credentials; also signs GitHub install state.
# Generate with `openssl rand -hex 32` (64 hex chars) or `openssl rand -base64 32`.
# Rotating it requires re-encrypting existing encrypted database values.
WALLIE_ENCRYPTION_KEY=replace-with-output-of-openssl-rand-hex-32

# GitHub App credentials. Required for the GitHub integration (repo linking,
# PR sync, webhooks). The server boots without them, but any GitHub-backed
# feature will fail until they're set.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Operator/dev Vercel Sandbox credentials. Workspace session execution uses the
# Vercel connection saved in Settings; these vars are only for non-session
# helper sandboxes or local operator testing.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Workspace settings select Vercel, E2B, or Daytona. Set this to "fake" only
# for tests/local development.
WALLIE_SANDBOX_IMPL=
# Comma-separated providers exposed in Settings. Defaults to all three.
WALLIE_ENABLED_SANDBOX_PROVIDERS=vercel,e2b,daytona
# Comma-separated exact Daytona API base URLs that workspace admins may use.
# Daytona Cloud is always allowed. Add private/self-hosted control planes here.
WALLIE_DAYTONA_API_URL_ALLOWLIST=
# Set to "1" in a canary to emit server loader timing logs.
WALLIE_TIMING_LOGS=
