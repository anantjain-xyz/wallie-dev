# Local defaults. On Vercel, mirror the same keys in project env settings and
# set NEXT_PUBLIC_APP_URL to the deployed origin for each environment.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-your-publishable-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=replace-with-your-secret-key
# Generate with `openssl rand -hex 32` (64 hex chars) or `openssl rand -base64 32`.
WALLIE_ENCRYPTION_KEY=replace-with-output-of-openssl-rand-hex-32

# GitHub App credentials. Required for the GitHub integration (repo linking,
# PR sync, webhooks). The server boots without them, but any GitHub-backed
# feature will fail until they're set.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Vercel Sandbox — required for agent execution unless running on Vercel infra
# (in which case OIDC is used automatically). Create a team-scoped token at
# https://vercel.com/account/tokens.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Sandbox implementation: "vercel" (default) or "fake" (tests / local without
# Vercel creds).
WALLIE_SANDBOX_IMPL=
# Set to "0" to skip Playwright bootstrap inside sandboxes.
WALLIE_SANDBOX_BOOTSTRAP_PLAYWRIGHT=

# Set to "1" to drop the Secure attribute from Codex OAuth cookies for local
# HTTP dev. Leave unset in every deployed environment.
WALLIE_ALLOW_INSECURE_COOKIES=

# Codex OAuth endpoints. Defaults target auth.openai.com with the public Codex
# CLI client_id; override only for testing or if OpenAI publishes a dedicated
# third-party client.
CODEX_OAUTH_CLIENT_ID=
CODEX_OAUTH_AUTHORIZE_URL=
CODEX_OAUTH_TOKEN_URL=
