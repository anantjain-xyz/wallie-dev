{
  "name": "wallie-dev",
  "version": "0.2.1",
  "private": false,
  "license": "MIT",
  "description": "AI-powered product development automation. Turn Linear issues into structured specs and ship them through a configurable, human-reviewed multi-stage agent pipeline.",
  "homepage": "https://wallie.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anantjain-xyz/wallie-dev.git"
  },
  "bugs": {
    "url": "https://github.com/anantjain-xyz/wallie-dev/issues"
  },
  "keywords": [
    "ai-agents",
    "developer-tools",
    "nextjs",
    "supabase",
    "automation",
    "linear",
    "github"
  ],
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "analyze:authenticated-bundle": "node scripts/analyze-authenticated-bundle.mjs",
    "dev": "next dev",
    "build": "next build",
    "check:route-budgets": "tsx scripts/check-route-budgets.ts",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e:session-prefetch": "pnpm build && playwright test e2e/session-detail-prefetch.spec.ts",
    "test:benchmark:interaction": "pnpm build && playwright test e2e/interaction-rum.benchmark.spec.ts --repeat-each=2",
    "test:watch": "vitest",
    "db:types": "SUPABASE_TELEMETRY_DISABLED=1 supabase gen types typescript --local > src/lib/supabase/database.types.ts && prettier --write src/lib/supabase/database.types.ts",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "worker": "node --env-file-if-exists=.env.local --import ./scripts/install-crash-handlers.mjs --import ./scripts/register-server-only.mjs --import tsx src/worker/index.ts"
  },
  "dependencies": {
    "@octokit/app": "^16.1.2",
    "@octokit/webhooks-methods": "^6.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/sandbox": "^1.10.0",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.1",
    "tsx": "^4.19.4",
    "unified": "^11.0.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axe-core": "^4.12.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.7"
  }
}
