# Local defaults. On Vercel, mirror the same keys in project env settings and
# set NEXT_PUBLIC_APP_URL to the deployed origin for each environment.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-your-publishable-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=replace-with-your-secret-key
WALLIE_ENCRYPTION_KEY=replace-with-a-32-character-minimum-secret

# Optional: use when calling POST /api/agent-jobs/process outside the app UI.
WALLIE_PROCESS_TOKEN=

# Optional until the corresponding integrations land.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Worker process (pnpm worker). All optional — sensible defaults are used.
WALLIE_WORKER_ID=
WALLIE_WORKER_POLL_INTERVAL_MS=
WALLIE_WORKER_HEARTBEAT_INTERVAL_MS=
WALLIE_WORKER_STALL_SWEEP_INTERVAL_MS=
WALLIE_WORKER_RECONCILE_INTERVAL_MS=
WALLIE_WORKER_DEFAULT_STALL_TIMEOUT_MS=
WALLIE_WORKER_DEFAULT_CONCURRENCY_LIMIT=
WALLIE_WORKSPACE_BASE_DIR=
